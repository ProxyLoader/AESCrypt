<!doctype html>
<html lang="en" class="h-full">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AESCrypt | Dashboard</title>
    <script src="/_sdk/element_sdk.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            box-sizing: border-box;
        }

        .gradient-bg {
            background: #0f172a;
        }

        .button-modern {
            transition: all 0.2s ease;
            border: 1px solid rgba(59, 130, 246, 0.2);
        }

        .button-modern:hover {
            background: rgba(59, 130, 246, 0.15);
            border-color: rgba(59, 130, 246, 0.4);
            transform: translateY(-1px);
        }

        .profile-container {
            border: 2px solid rgba(59, 130, 246, 0.3);
        }

        .custom-scrollbar::-webkit-scrollbar {
            width: 8px;
        }

        .custom-scrollbar::-webkit-scrollbar-track {
            background: rgba(30, 41, 59, 0.5);
        }

        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: rgba(71, 85, 105, 0.8);
            border-radius: 4px;
        }

        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: rgba(96, 165, 250, 0.6);
        }
    </style>
    <style>
        @view-transition {
            navigation: auto;
        }
    </style>
    <script src="/_sdk/data_sdk.js" type="text/javascript"></script>
</head>

<body class="h-full">
    <div class="gradient-bg w-full h-full flex flex-col overflow-auto">
        <header class="flex justify-end items-center px-4 sm:px-8 py-4 sm:py-6 relative">
            <button id="profileBtn" class="profile-container rounded-full p-0.5 bg-slate-800 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-opacity-50 cursor-pointer hover:bg-slate-700 transition-all">
                <div id="profilePicContainer" class="w-10 h-10 sm:w-12 sm:h-12 rounded-full bg-slate-700 flex items-center justify-center text-blue-400 overflow-hidden">
                    <svg id="defaultAvatar" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 sm:w-7 sm:h-7" fill="none" viewbox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                    <img id="userAvatar" class="hidden w-full h-full object-cover" alt="Profile" onerror="this.style.display='none'; document.getElementById('defaultAvatar').classList.remove('hidden');">
                </div>
            </button>
            <div id="profileMenu" class="hidden absolute top-16 right-4 sm:right-8 bg-slate-800 border border-blue-500 border-opacity-30 rounded-xl shadow-xl overflow-hidden z-50 min-w-[200px]">
                <button id="secretKeyBtn" class="w-full px-4 py-3 text-left text-white hover:bg-slate-700 transition-all flex items-center gap-2 border-b border-slate-700">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-400" fill="none" viewbox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
                    </svg> Set Secret Key
                </button>
                <button id="devModeToggle" class="w-full px-4 py-3 text-left text-white hover:bg-slate-700 transition-all flex items-center justify-between gap-3">
                    <span class="flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-400" fill="none" viewbox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                        </svg> Developer Mode
                    </span>
                    <span id="devModeStatus" class="text-xs px-2 py-1 rounded-full bg-slate-700 text-slate-400">OFF</span>
                </button>
            </div>
        </header>

        <main class="flex-1 flex items-center justify-center px-4 sm:px-8 pb-8 sm:pb-16">
            <div class="flex flex-col sm:flex-row gap-4 sm:gap-6 items-center justify-center w-full max-w-2xl">
                <button id="uploadBtn" class="button-modern bg-slate-800 hover:bg-slate-800 text-white font-medium text-base sm:text-lg px-8 sm:px-10 py-5 sm:py-6 rounded-xl w-full sm:w-auto sm:min-w-[180px] focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-opacity-50">
                    <div class="flex flex-col items-center gap-2 sm:gap-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 sm:w-8 sm:h-8 text-blue-400" fill="none" viewbox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
                        </svg>
                        <span id="uploadBtnText">Upload</span>
                    </div>
                </button>
                <button id="retrieveBtn" class="button-modern bg-slate-800 hover:bg-slate-800 text-white font-medium text-base sm:text-lg px-8 sm:px-10 py-5 sm:py-6 rounded-xl w-full sm:w-auto sm:min-w-[180px] focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-opacity-50">
                    <div class="flex flex-col items-center gap-2 sm:gap-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 sm:w-8 sm:h-8 text-blue-400" fill="none" viewbox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10" />
                        </svg>
                        <span id="retrieveBtnText">Retrieve</span>
                    </div>
                </button>
            </div>
        </main>

        <div id="repoSetupModal" class="hidden fixed inset-0 bg-black bg-opacity-80 flex items-center justify-center px-4 z-50">
            <div class="bg-slate-800 border border-blue-500 border-opacity-30 rounded-2xl p-6 sm:p-8 max-w-md w-full">
                <div class="text-center mb-6">
                    <div class="inline-flex items-center justify-center w-14 h-14 bg-blue-500 bg-opacity-20 rounded-full mb-4">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-blue-400" fill="none" viewbox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
                        </svg>
                    </div>
                    <h2 class="text-xl sm:text-2xl font-semibold text-white mb-3">Setup Required</h2>
                    <p class="text-slate-300 text-sm sm:text-base leading-relaxed">Before you continue, we need to create a repository called <span class="text-blue-400 font-medium">LambdaVault</span> to store your data.</p>
                </div>
                <button id="confirmCreateBtn" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-medium py-3 px-6 rounded-xl transition-all focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-opacity-50 flex items-center justify-center gap-2">
                    <svg id="loadingSpinner" class="hidden animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewbox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z" />
                    </svg>
                    <span id="btnText">Confirm</span>
                </button>
            </div>
        </div>

        <div id="secretKeyModal" class="hidden fixed inset-0 bg-black bg-opacity-80 flex items-center justify-center px-4 z-50">
            <div class="bg-slate-800 border border-blue-500 border-opacity-30 rounded-2xl p-6 sm:p-8 max-w-md w-full">
                <div class="mb-6">
                    <div class="inline-flex items-center justify-center w-14 h-14 bg-blue-500 bg-opacity-20 rounded-full mb-4">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-blue-400" fill="none" viewbox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
                        </svg>
                    </div>
                    <h2 class="text-xl sm:text-2xl font-semibold text-white mb-3">Set Secret Key</h2>
                    <p class="text-slate-300 text-sm sm:text-base leading-relaxed mb-4">This key will be used to encrypt your files while uploading, and decrypt them when retrieving.</p>
                    <div class="space-y-4">
                        <div>
                            <label for="secretKeyInput" class="block text-sm font-medium text-slate-300 mb-2">Secret Key (AES-256)</label>
                            <div class="relative">
                                <input type="password" id="secretKeyInput" placeholder="Enter your secret key" class="w-full bg-slate-700 border border-slate-600 text-white rounded-lg px-4 py-3 pr-12 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                                <button id="togglePasswordBtn" class="absolute right-3 top-1/2 transform -translate-y-1/2 text-slate-400 hover:text-slate-200 focus:outline-none">
                                    <svg id="eyeIcon" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewbox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                    </svg>
                                    <svg id="eyeOffIcon" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 hidden" fill="none" viewbox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />
                                    </svg>
                                </button>
                            </div>
                        </div>
                        <div class="bg-slate-700 bg-opacity-50 rounded-lg p-4 border border-slate-600">
                            <div class="flex items-start gap-2 mb-3">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-yellow-400 flex-shrink-0 mt-0.5" fill="none" viewbox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                                </svg>
                                <div class="flex-1">
                                    <p class="text-sm text-slate-300 font-medium mb-2">Generate Secure Key</p>
                                    <p class="text-xs text-slate-400 mb-3">First time? Generate a random AES-256 key (32 characters)</p>
                                    <button id="generateKeyBtn" class="w-full bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium py-2 px-4 rounded-lg transition-all focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-opacity-50"> Generate Random Key </button>
                                </div>
                            </div>
                        </div>
                        <div id="successMessage" class="hidden bg-green-600 bg-opacity-20 border border-green-500 rounded-lg p-3 flex items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-green-400" fill="none" viewbox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                            </svg>
                            <span class="text-sm text-green-300 font-medium">Secret key saved successfully!</span>
                        </div>
                    </div>
                </div>
                <div class="flex gap-3">
                    <button id="cancelSecretKeyBtn" class="flex-1 bg-slate-700 hover:bg-slate-600 text-white font-medium py-3 px-6 rounded-xl transition-all focus:outline-none focus:ring-2 focus:ring-slate-500 focus:ring-opacity-50"> Cancel </button>
                    <button id="saveSecretKeyBtn" class="flex-1 bg-blue-600 hover:bg-blue-700 text-white font-medium py-3 px-6 rounded-xl transition-all focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-opacity-50"> Save </button>
                </div>
            </div>
        </div>

        <div id="uploadModal" class="hidden fixed inset-0 bg-black bg-opacity-80 flex items-center justify-center px-4 z-50">
            <div class="bg-slate-800 border border-blue-500 border-opacity-30 rounded-2xl p-6 sm:p-8 max-w-2xl w-full max-h-[90%] overflow-y-auto">
                <div class="mb-6">
                    <div class="inline-flex items-center justify-center w-14 h-14 bg-blue-500 bg-opacity-20 rounded-full mb-4">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-blue-400" fill="none" viewbox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
                        </svg>
                    </div>
                    <h2 class="text-xl sm:text-2xl font-semibold text-white mb-3">Upload Files</h2>
                    <p class="text-slate-300 text-sm sm:text-base leading-relaxed mb-4">Select files to upload. Total size must not exceed 100 MB.</p>
                    <div class="border-2 border-dashed border-slate-600 rounded-xl p-8 text-center hover:border-blue-500 transition-all cursor-pointer mb-4" id="dropZone">
                        <input type="file" id="fileInput" multiple class="hidden" accept="*/*">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-slate-400 mx-auto mb-3" fill="none" viewbox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 13h6m-3-3v6m5 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                        <p class="text-white font-medium mb-1">Click to browse or drag files here</p>
                        <p class="text-slate-400 text-sm">Maximum total size: 100 MB</p>
                    </div>
                    <div id="filesList" class="hidden space-y-2 mb-4 max-h-60 overflow-y-auto">
                        <div class="flex items-center justify-between text-sm text-slate-300 mb-2 pb-2 border-b border-slate-700">
                            <span class="font-medium">Selected Files</span>
                            <span id="totalSize" class="text-xs px-2 py-1 bg-slate-700 rounded">0 MB / 100 MB</span>
                        </div>
                    </div>
                    <div id="uploadError" class="hidden bg-red-600 bg-opacity-20 border border-red-500 rounded-lg p-3 mb-4">
                        <div class="flex items-start gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-red-400 flex-shrink-0 mt-0.5" fill="none" viewbox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            <span id="uploadErrorText" class="text-sm text-red-300"></span>
                        </div>
                    </div>
                    <div id="uploadProgress" class="hidden mb-4">
                        <div class="flex items-center justify-between text-sm text-slate-300 mb-2">
                            <span>Uploading...</span>
                            <span id="uploadPercentage">0%</span>
                        </div>
                        <div class="w-full h-2 bg-slate-700 rounded-full overflow-hidden">
                            <div id="uploadProgressBar" class="h-full bg-gradient-to-r from-blue-600 to-blue-400 transition-all" style="width: 0%"></div>
                        </div>
                    </div>
                    <div id="uploadSuccess" class="hidden bg-green-600 bg-opacity-20 border border-green-500 rounded-lg p-3 mb-4">
                        <div class="flex items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-green-400" fill="none" viewbox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                            </svg>
                            <span class="text-sm text-green-300 font-medium">Files uploaded successfully!</span>
                        </div>
                    </div>
                </div>
                <div class="flex gap-3">
                    <button id="cancelUploadBtn" class="flex-1 bg-slate-700 hover:bg-slate-600 text-white font-medium py-3 px-6 rounded-xl transition-all focus:outline-none focus:ring-2 focus:ring-slate-500 focus:ring-opacity-50"> Cancel </button>
                    <button id="confirmUploadBtn" class="flex-1 bg-blue-600 hover:bg-blue-700 text-white font-medium py-3 px-6 rounded-xl transition-all focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-opacity-50 disabled:opacity-50 disabled:cursor-not-allowed" disabled> Upload Files </button>
                </div>
            </div>
        </div>

        <div id="retrieveModal" class="hidden fixed inset-0 bg-black bg-opacity-80 flex items-center justify-center px-4 z-50">
            <div class="bg-slate-800 border border-blue-500 border-opacity-30 rounded-2xl p-6 sm:p-8 max-w-4xl w-full max-h-[90%] flex flex-col">
                <div class="flex justify-between items-center mb-6 flex-shrink-0">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 bg-blue-500 bg-opacity-20 rounded-full flex items-center justify-center">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />
                            </svg>
                        </div>
                        <h2 class="text-xl sm:text-2xl font-semibold text-white">Your Vault</h2>
                    </div>
                    <div class="flex items-center gap-2">
                        <button id="refreshRetrieveBtn" class="p-2 text-slate-400 hover:text-blue-400 bg-slate-700 hover:bg-slate-600 rounded-lg transition-all" title="Refresh">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                            </svg>
                        </button>
                        <button id="closeRetrieveBtn" class="text-slate-400 hover:text-white transition-colors ml-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                            </svg>
                        </button>
                    </div>
                </div>

                <div id="vaultFilesList" class="flex-1 overflow-y-auto space-y-2 pr-2 custom-scrollbar min-h-[300px]">
                    <div id="loadingMsg" class="text-center text-slate-500 py-10 hidden">Loading files...</div>
                    <div id="emptyMsg" class="text-center text-slate-500 py-10 hidden">No files found.</div>
                </div>

                <div id="paginationControls" class="flex justify-between items-center mt-4 pt-4 border-t border-slate-700 hidden">
                    <button id="prevPageBtn" class="px-4 py-2 bg-slate-700 hover:bg-slate-600 text-white rounded-lg disabled:opacity-50 disabled:cursor-not-allowed transition-colors text-sm font-medium">Previous</button>
                    <span id="pageIndicator" class="text-slate-300 text-sm">Page 1</span>
                    <button id="nextPageBtn" class="px-4 py-2 bg-slate-700 hover:bg-slate-600 text-white rounded-lg disabled:opacity-50 disabled:cursor-not-allowed transition-colors text-sm font-medium">Next</button>
                </div>

                <div class="mt-6 pt-4 border-t border-slate-700 flex justify-end flex-shrink-0">
                    <button id="doneRetrieveBtn" class="bg-slate-700 hover:bg-slate-600 text-white font-medium py-2 px-6 rounded-xl transition-all">Done</button>
                </div>
            </div>
        </div>

        <div id="warningModal" class="hidden fixed inset-0 bg-black bg-opacity-90 flex items-center justify-center px-4 z-50">
            <div class="bg-slate-800 border-2 border-red-500 border-opacity-50 rounded-2xl p-6 sm:p-8 max-w-lg w-full">
                <div class="text-center mb-6">
                    <div class="inline-flex items-center justify-center w-16 h-16 bg-red-500 bg-opacity-20 rounded-full mb-4 animate-pulse">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-red-400" fill="none" viewbox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                        </svg>
                    </div>
                    <h2 class="text-2xl sm:text-3xl font-bold text-red-400 mb-4">⚠️ EXTREME CAUTION ⚠️</h2>
                    <div class="bg-red-900 bg-opacity-30 rounded-lg p-4 mb-4">
                        <p class="text-white font-semibold text-lg mb-3">YOU MUST SAVE THIS KEY!</p>
                        <p class="text-slate-200 text-sm leading-relaxed mb-3">Write down this secret key and store it in a safe physical location. If you lose this key, <span class="text-red-400 font-bold">you will NEVER be able to decrypt your files again!</span></p>
                        <div class="bg-slate-700 rounded-lg p-3 mb-3 border border-slate-600">
                            <p class="text-xs text-slate-400 mb-2">Your Secret Key:</p>
                            <p id="keyToSave" class="text-white font-mono text-sm break-all select-all"></p>
                        </div>
                        <p class="text-yellow-300 text-xs">💡 Tip: Write it on paper, store it in a password manager, or save it in multiple secure locations.</p>
                    </div>
                </div>
                <div class="flex flex-col gap-3">
                    <button id="printKeyBtn" class="w-full bg-slate-700 hover:bg-slate-600 text-white font-medium py-3 px-6 rounded-xl transition-all focus:outline-none focus:ring-2 focus:ring-slate-500 focus:ring-opacity-50 flex items-center justify-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewbox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
                        </svg> Print Keys as PDF
                    </button>
                    <button id="acknowledgeBtn" class="w-full bg-red-600 hover:bg-red-700 text-white font-bold py-4 px-6 rounded-xl transition-all focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-opacity-50 text-lg"> I Understand, I've Saved My Key </button>
                </div>
            </div>
        </div>
    </div>
    <script>
        const defaultConfig = {
            background_color: "#0f172a",
            accent_color: "#3b82f6",
            button_primary_color: "#2563eb",
            button_hover_color: "#3b82f6",
            text_color: "#ffffff",
            upload_button_text: "Upload",
            retrieve_button_text: "Retrieve"
        };
        const config = {};

        async function onConfigChange(updatedConfig) {
            const uploadBtnText = document.getElementById('uploadBtnText');
            const retrieveBtnText = document.getElementById('retrieveBtnText');

            if (uploadBtnText) {
                uploadBtnText.textContent = updatedConfig.upload_button_text || defaultConfig.upload_button_text;
            }

            if (retrieveBtnText) {
                retrieveBtnText.textContent = updatedConfig.retrieve_button_text || defaultConfig.retrieve_button_text;
            }

            const buttons = document.querySelectorAll('.button-modern');
            buttons.forEach(button => {
                const primaryColor = updatedConfig.button_primary_color || defaultConfig.button_primary_color;
                const textColor = updatedConfig.text_color || defaultConfig.text_color;

                button.style.backgroundColor = primaryColor;
                button.style.color = textColor;
            });
            const icons = document.querySelectorAll('.button-modern svg');
            icons.forEach(icon => {
                const accentColor = updatedConfig.accent_color || defaultConfig.accent_color;
                icon.style.color = accentColor;
            });
        }

        function mapToCapabilities(config) {
            return {
                recolorables: [{
                        get: () => config.background_color || defaultConfig.background_color,
                        set: (value) => {
                            config.background_color = value;
                            window.elementSdk.setConfig({
                                background_color: value
                            });
                        }
                    },
                    {
                        get: () => config.button_primary_color || defaultConfig.button_primary_color,
                        set: (value) => {
                            config.button_primary_color = value;
                            window.elementSdk.setConfig({
                                button_primary_color: value
                            });
                        }
                    },
                    {
                        get: () => config.accent_color || defaultConfig.accent_color,
                        set: (value) => {
                            config.accent_color = value;
                            window.elementSdk.setConfig({
                                accent_color: value
                            });
                        }
                    },
                    {
                        get: () => config.text_color || defaultConfig.text_color,
                        set: (value) => {
                            config.text_color = value;
                            window.elementSdk.setConfig({
                                text_color: value
                            });
                        }
                    }
                ],
                borderables: [],
                fontEditable: undefined,
                fontSizeable: undefined
            };
        }

        function mapToEditPanelValues(config) {
            return new Map([
                ["upload_button_text", config.upload_button_text || defaultConfig.upload_button_text],
                ["retrieve_button_text", config.retrieve_button_text || defaultConfig.retrieve_button_text]
            ]);
        }

        if (window.elementSdk) {
            window.elementSdk.init({
                defaultConfig,
                onConfigChange,
                mapToCapabilities,
                mapToEditPanelValues
            });
        }

        function initiateDecrypt(downloadUrl) {
            const secret = localStorage.getItem('secret_key');
            if (!secret) {
                alert("Secret key is missing! Please set it in the profile menu.");
                return;
            }

            const elink = btoa(downloadUrl);
            const encodedSecret = btoa(secret);

            const targetUrl = `/decrypt?elink=${encodeURIComponent(elink)}&secret=${encodeURIComponent(encodedSecret)}`;

            const tempLink = document.createElement('a');
            tempLink.style.display = 'none';
            tempLink.href = targetUrl;
            tempLink.setAttribute('download', '');
            document.body.appendChild(tempLink);
            tempLink.click();
            document.body.removeChild(tempLink);
        }

        async function checkRepo() {
            const devMode = localStorage.getItem('dev_mode') === 'true';
            if (devMode) {
                const gistToken = localStorage.getItem('gist_token');
                if (gistToken) {
                    await fetchAvatar(gistToken);
                }
                return;
            }

            const gistToken = localStorage.getItem('gist_token');
            if (!gistToken) {
                showRepoSetupModal();
                return;
            }

            try {
                const response = await fetch(`/repo_check?token=${encodeURIComponent(gistToken)}`, {
                    method: 'POST'
                });
                if (response.status !== 200) {
                    showRepoSetupModal();
                } else {
                    await fetchAvatar(gistToken);
                }
            } catch (error) {
                showRepoSetupModal();
            }
        }

        async function fetchAvatar(token) {
            try {
                const response = await fetch(`/get_avatar?token=${encodeURIComponent(token)}`, {
                    method: 'GET'
                });
                if (response.status === 200) {
                    const data = await response.json();
                    if (data.link) {
                        const userAvatar = document.getElementById('userAvatar');
                        const defaultAvatar = document.getElementById('defaultAvatar');

                        userAvatar.src = data.link;
                        userAvatar.classList.remove('hidden');
                        defaultAvatar.classList.add('hidden');
                    }
                }
            } catch (error) {
                console.error('Failed to fetch avatar:', error);
            }
        }

        function showRepoSetupModal() {
            const modal = document.getElementById('repoSetupModal');
            modal.classList.remove('hidden');
        }

        function hideRepoSetupModal() {
            const modal = document.getElementById('repoSetupModal');
            modal.classList.add('hidden');
        }

        async function createLambdaRepo() {
            const gistToken = localStorage.getItem('gist_token');
            const confirmBtn = document.getElementById('confirmCreateBtn');
            const loadingSpinner = document.getElementById('loadingSpinner');
            const btnText = document.getElementById('btnText');

            confirmBtn.disabled = true;
            loadingSpinner.classList.remove('hidden');
            btnText.textContent = 'Creating...';
            try {
                const response = await fetch(`/createLambda?token=${encodeURIComponent(gistToken)}`, {
                    method: 'POST'
                });
                if (response.status === 200) {
                    window.location.reload();
                } else {
                    confirmBtn.disabled = false;
                    loadingSpinner.classList.add('hidden');
                    btnText.textContent = 'Confirm';
                }
            } catch (error) {
                confirmBtn.disabled = false;
                loadingSpinner.classList.add('hidden');
                btnText.textContent = 'Confirm';
            }
        }

        const uploadModal = document.getElementById('uploadModal');
        const uploadBtn = document.getElementById('uploadBtn');
        const cancelUploadBtn = document.getElementById('cancelUploadBtn');
        const confirmUploadBtn = document.getElementById('confirmUploadBtn');
        const fileInput = document.getElementById('fileInput');
        const dropZone = document.getElementById('dropZone');
        const filesList = document.getElementById('filesList');
        const totalSize = document.getElementById('totalSize');
        const uploadError = document.getElementById('uploadError');
        const uploadErrorText = document.getElementById('uploadErrorText');
        const uploadProgress = document.getElementById('uploadProgress');
        const uploadPercentage = document.getElementById('uploadPercentage');
        const uploadProgressBar = document.getElementById('uploadProgressBar');
        const uploadSuccess = document.getElementById('uploadSuccess');

        let selectedFiles = [];
        const MAX_SIZE = 100 * 1024 * 1024;

        uploadBtn.addEventListener('click', () => {
            const secretKey = localStorage.getItem('secret_key');
            if (!secretKey) {
                uploadError.classList.remove('hidden');
                uploadErrorText.textContent = 'Please set a secret key first!';
                setTimeout(() => {

                    uploadError.classList.add('hidden');
                    secretKeyModal.classList.remove('hidden');
                }, 2000);
                return;
            }

            uploadModal.classList.remove('hidden');
            resetUploadModal();
        });

        const retrieveModal = document.getElementById('retrieveModal');
        const vaultFilesList = document.getElementById('vaultFilesList');
        const closeRetrieveBtn = document.getElementById('closeRetrieveBtn');
        const doneRetrieveBtn = document.getElementById('doneRetrieveBtn');
        const refreshRetrieveBtn = document.getElementById('refreshRetrieveBtn');
        const loadingMsg = document.getElementById('loadingMsg');
        const emptyMsg = document.getElementById('emptyMsg');
        const paginationControls = document.getElementById('paginationControls');
        const prevPageBtn = document.getElementById('prevPageBtn');
        const nextPageBtn = document.getElementById('nextPageBtn');
        const pageIndicator = document.getElementById('pageIndicator');

        let cachedFiles = [];
        let currentPage = 1;
        const itemsPerPage = 8;

        document.getElementById('retrieveBtn').addEventListener('click', async () => {
            const token = localStorage.getItem("gist_token");

            if (!token) {
                alert("GitHub Token not found. Please setup the repo first.");
                return;
            }

            retrieveModal.classList.remove('hidden');

            if (cachedFiles.length > 0) {
                renderVaultFiles();
            } else {
                await fetchAndRenderFiles();
            }

        });

        refreshRetrieveBtn.addEventListener('click', async () => {
            await fetchAndRenderFiles();
        });

        async function fetchAndRenderFiles() {
            const token = localStorage.getItem("gist_token");
            const secret = localStorage.getItem("secret_key");

            currentPage = 1;
            cachedFiles = [];
            vaultFilesList.innerHTML = '';
            loadingMsg.classList.remove('hidden');
            emptyMsg.classList.add('hidden');
            paginationControls.classList.add('hidden');

            try {
                const response = await fetch("/retrive?token=" + token + "&secret=" + btoa(secret));
                const data = await response.json();

                loadingMsg.classList.add('hidden');

                if (!data || data.length === 0) {
                    emptyMsg.classList.remove('hidden');
                    cachedFiles = [];
                } else {
                    cachedFiles = data;
                    renderVaultFiles();
                }

            } catch (e) {
                console.error(e);
                loadingMsg.classList.add('hidden');
                vaultFilesList.innerHTML = '<div class="text-center text-red-400 py-10">Failed to retrieve files. Please try refreshing.</div>';
            }
        }

        function renderVaultFiles() {
            vaultFilesList.innerHTML = '';
            if (cachedFiles.length === 0) {
                emptyMsg.classList.remove('hidden');
                paginationControls.classList.add('hidden');
                return;
            }

            const totalPages = Math.ceil(cachedFiles.length / itemsPerPage);
            if (currentPage > totalPages) currentPage = totalPages;
            if (currentPage < 1) currentPage = 1;

            const startIndex = (currentPage - 1) * itemsPerPage;
            const endIndex = startIndex + itemsPerPage;
            const filesToRender = cachedFiles.slice(startIndex, endIndex);

            filesToRender.forEach(file => {
                const fileRow = document.createElement('div');
                fileRow.className = 'flex items-center justify-between bg-slate-700/50 hover:bg-slate-700 border border-slate-600 rounded-xl p-4 transition-all group';

                fileRow.innerHTML = `
                <div class="flex items-center gap-3 overflow-hidden">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-blue-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                    <div class="truncate">
                        <p class="text-white text-sm font-medium truncate" title="${file.name}">${file.name}</p>
                        <p class="text-slate-400 text-xs uppercase">${file.name.split('.').pop()}</p>
                    </div>
                </div>
                <div class="flex items-center gap-2">
                    <button class="p-2 text-slate-400 hover:text-yellow-400 hover:bg-yellow-400/10 rounded-lg transition-all" title="Decrypt" onclick="initiateDecrypt('${file.downloadUrl}')">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 11V7a4 4 0 118 0m-4 8v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2z" />
                        </svg>
                    </button>
                    <a href="${file.downloadUrl}" target="_blank" download="${file.name}" class="p-2 text-slate-400 hover:text-green-400 hover:bg-green-400/10 rounded-lg transition-all" title="Download Encrypted">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                        </svg>
                    </a>
                </div>
            `;
                vaultFilesList.appendChild(fileRow);
            });

            if (totalPages > 1) {
                paginationControls.classList.remove('hidden');
                pageIndicator.textContent = `Page ${currentPage} of ${totalPages}`;

                prevPageBtn.disabled = currentPage === 1;
                nextPageBtn.disabled = currentPage === totalPages;
            } else {
                paginationControls.classList.add('hidden');
            }
        }

        prevPageBtn.addEventListener('click', () => {
            if (currentPage > 1) {
                currentPage--;
                renderVaultFiles();
            }
        });
        nextPageBtn.addEventListener('click', () => {
            const totalPages = Math.ceil(cachedFiles.length / itemsPerPage);
            if (currentPage < totalPages) {
                currentPage++;
                renderVaultFiles();
            }
        });

        function closeRetrieveModal() {
            retrieveModal.classList.add('hidden');
        }

        closeRetrieveBtn.addEventListener('click', closeRetrieveModal);
        doneRetrieveBtn.addEventListener('click', closeRetrieveModal);

        function resetUploadModal() {
            selectedFiles = [];
            fileInput.value = '';
            filesList.classList.add('hidden');
            uploadError.classList.add('hidden');
            uploadProgress.classList.add('hidden');
            uploadSuccess.classList.add('hidden');
            confirmUploadBtn.disabled = true;
            updateFilesList();
        }

        dropZone.addEventListener('click', () => {
            fileInput.click();
        });

        fileInput.addEventListener('change', (e) => {
            handleFiles(e.target.files);
        });

        dropZone.addEventListener('dragover', (e) => {
            e.preventDefault();
            dropZone.classList.add('border-blue-500');
        });
        dropZone.addEventListener('dragleave', () => {
            dropZone.classList.remove('border-blue-500');
        });
        dropZone.addEventListener('drop', (e) => {
            e.preventDefault();
            dropZone.classList.remove('border-blue-500');
            handleFiles(e.dataTransfer.files);
        });

        function handleFiles(files) {
            selectedFiles = Array.from(files);
            const totalBytes = selectedFiles.reduce((sum, file) => sum + file.size, 0);
            if (totalBytes > MAX_SIZE) {
                uploadError.classList.remove('hidden');
                uploadErrorText.textContent = `Total file size (${(totalBytes / 1024 / 1024).toFixed(2)} MB) exceeds the 100 MB limit!`;
                selectedFiles = [];
                fileInput.value = '';
                confirmUploadBtn.disabled = true;
                filesList.classList.add('hidden');
                return;
            }

            uploadError.classList.add('hidden');
            updateFilesList();
            confirmUploadBtn.disabled = selectedFiles.length === 0;
        }

        function updateFilesList() {
            if (selectedFiles.length === 0) {
                filesList.classList.add('hidden');
                return;
            }

            filesList.classList.remove('hidden');
            const totalBytes = selectedFiles.reduce((sum, file) => sum + file.size, 0);
            totalSize.textContent = `${(totalBytes / 1024 / 1024).toFixed(2)} MB / 100 MB`;
            const existingFiles = filesList.querySelectorAll('.file-item');
            existingFiles.forEach(item => item.remove());
            selectedFiles.forEach((file, index) => {
                const fileItem = document.createElement('div');
                fileItem.className = 'file-item flex items-center justify-between bg-slate-700 rounded-lg p-3';

                const fileInfo = document.createElement('div');
                fileInfo.className = 'flex items-center gap-3 flex-1 min-w-0';

                const fileIcon = document.createElement('div');
                fileIcon.className = 'flex-shrink-0';
                fileIcon.innerHTML = `
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
          </svg>
        `;

                const fileDetails = document.createElement('div');
                fileDetails.className = 'flex-1 min-w-0';
                fileDetails.innerHTML = `
          <p class="text-white text-sm font-medium truncate">${file.name}</p>
          <p class="text-slate-400 text-xs">${(file.size / 1024).toFixed(2)} KB</p>
        `;
                const removeBtn = document.createElement('button');
                removeBtn.className = 'flex-shrink-0 text-red-400 hover:text-red-300 transition-colors';
                removeBtn.innerHTML = `
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        `;
                removeBtn.addEventListener('click', () => {
                    selectedFiles.splice(index, 1);
                    updateFilesList();
                    confirmUploadBtn.disabled = selectedFiles.length === 0;
                });
                fileInfo.appendChild(fileIcon);
                fileInfo.appendChild(fileDetails);
                fileItem.appendChild(fileInfo);
                fileItem.appendChild(removeBtn);
                filesList.appendChild(fileItem);
            });
        }

        cancelUploadBtn.addEventListener('click', () => {
            uploadModal.classList.add('hidden');
            resetUploadModal();
        });

        confirmUploadBtn.addEventListener('click', async () => {
            if (selectedFiles.length === 0) return;

            const gistToken = localStorage.getItem('gist_token');
            if (!gistToken) {
                uploadError.classList.remove('hidden');
                uploadErrorText.textContent = 'No GitHub token found. Please check your setup.';
                return;
            }

            confirmUploadBtn.disabled = true;
            cancelUploadBtn.disabled = true;

            uploadProgress.classList.remove('hidden');
            uploadError.classList.add('hidden');
            uploadSuccess.classList.add('hidden');

            try {
                const formData = new FormData();
                selectedFiles.forEach(file => {

                    formData.append('files', file);
                });

                uploadPercentage.textContent = '0%';
                uploadProgressBar.style.width = '0%';
                const secretKey = localStorage.getItem('secret_key');
                const secretKeyBase64 = btoa(secretKey);

                const response = await fetch(`/upload?token=${encodeURIComponent(gistToken)}&secret=${encodeURIComponent(secretKeyBase64)}`, {
                    method: 'POST',
                    body: formData
                });

                let progress = 0;
                const progressInterval = setInterval(() => {
                    progress += 10;
                    if (progress <= 90) {
                        uploadPercentage.textContent = `${progress}%`;
                        uploadProgressBar.style.width = `${progress}%`;
                    }
                }, 100);
                if (response.ok) {
                    const result = await response.json();
                    clearInterval(progressInterval);
                    uploadPercentage.textContent = '100%';
                    uploadProgressBar.style.width = '100%';
                    setTimeout(() => {
                        uploadProgress.classList.add('hidden');
                        uploadSuccess.classList.remove('hidden');

                        setTimeout(() => {
                            uploadModal.classList.add('hidden');

                            resetUploadModal();
                            cancelUploadBtn.disabled = false;
                        }, 2000);
                    }, 500);
                } else {
                    clearInterval(progressInterval);
                    const errorData = await response.text();
                    uploadProgress.classList.add('hidden');
                    uploadError.classList.remove('hidden');
                    uploadErrorText.textContent = `Upload failed: ${errorData}`;
                    confirmUploadBtn.disabled = false;
                    cancelUploadBtn.disabled = false;
                }
            } catch (error) {
                uploadProgress.classList.add('hidden');
                uploadError.classList.remove('hidden');
                uploadErrorText.textContent = `Upload error: ${error.message}`;
                confirmUploadBtn.disabled = false;
                cancelUploadBtn.disabled = false;
            }
        });

        document.getElementById('confirmCreateBtn').addEventListener('click', createLambdaRepo);
        const profileBtn = document.getElementById('profileBtn');
        const profileMenu = document.getElementById('profileMenu');
        profileBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            profileMenu.classList.toggle('hidden');
        });
        document.addEventListener('click', (e) => {
            if (!profileMenu.contains(e.target) && !profileBtn.contains(e.target)) {
                profileMenu.classList.add('hidden');
            }
        });
        const devModeToggle = document.getElementById('devModeToggle');
        const devModeStatus = document.getElementById('devModeStatus');

        function updateDevModeUI() {
            const devMode = localStorage.getItem('dev_mode') === 'true';
            if (devMode) {
                devModeStatus.textContent = 'ON';
                devModeStatus.classList.remove('bg-slate-700', 'text-slate-400');
                devModeStatus.classList.add('bg-green-600', 'text-white');
            } else {
                devModeStatus.textContent = 'OFF';
                devModeStatus.classList.remove('bg-green-600', 'text-white');
                devModeStatus.classList.add('bg-slate-700', 'text-slate-400');
            }
        }

        updateDevModeUI();
        devModeToggle.addEventListener('click', () => {
            const currentMode = localStorage.getItem('dev_mode') === 'true';
            localStorage.setItem('dev_mode', !currentMode);
            updateDevModeUI();
            profileMenu.classList.add('hidden');
        });
        const secretKeyBtn = document.getElementById('secretKeyBtn');
        const secretKeyModal = document.getElementById('secretKeyModal');
        const cancelSecretKeyBtn = document.getElementById('cancelSecretKeyBtn');
        const saveSecretKeyBtn = document.getElementById('saveSecretKeyBtn');
        const secretKeyInput = document.getElementById('secretKeyInput');
        const generateKeyBtn = document.getElementById('generateKeyBtn');
        const togglePasswordBtn = document.getElementById('togglePasswordBtn');
        const eyeIcon = document.getElementById('eyeIcon');
        const eyeOffIcon = document.getElementById('eyeOffIcon');
        const successMessage = document.getElementById('successMessage');
        const warningModal = document.getElementById('warningModal');
        const keyToSave = document.getElementById('keyToSave');
        const acknowledgeBtn = document.getElementById('acknowledgeBtn');
        togglePasswordBtn.addEventListener('click', () => {
            if (secretKeyInput.type === 'password') {
                secretKeyInput.type = 'text';
                eyeIcon.classList.add('hidden');
                eyeOffIcon.classList.remove('hidden');
            } else {
                secretKeyInput.type = 'password';
                eyeIcon.classList.remove('hidden');
                eyeOffIcon.classList.add('hidden');
            }
        });
        generateKeyBtn.addEventListener('click', () => {
            const charset = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*';
            let key = '';
            for (let i = 0; i < 32; i++) {
                key += charset.charAt(Math.floor(Math.random() * charset.length));
            }
            secretKeyInput.value = key;
            secretKeyInput.type = 'text';
            eyeIcon.classList.add('hidden');

            eyeOffIcon.classList.remove('hidden');
        });

        secretKeyBtn.addEventListener('click', () => {
            profileMenu.classList.add('hidden');
            secretKeyModal.classList.remove('hidden');
            successMessage.classList.add('hidden');
            const existingKey = localStorage.getItem('secret_key');
            if (existingKey) {
                secretKeyInput.value = existingKey;
            }
        });
        cancelSecretKeyBtn.addEventListener('click', () => {
            secretKeyModal.classList.add('hidden');
            secretKeyInput.value = '';
            secretKeyInput.type = 'password';
            eyeIcon.classList.remove('hidden');
            eyeOffIcon.classList.add('hidden');
            successMessage.classList.add('hidden');
        });
        saveSecretKeyBtn.addEventListener('click', () => {
            const secretKey = secretKeyInput.value.trim();
            if (secretKey) {
                keyToSave.textContent = secretKey;
                secretKeyModal.classList.add('hidden');
                warningModal.classList.remove('hidden');
            }
        });
        acknowledgeBtn.addEventListener('click', () => {
            const secretKey = keyToSave.textContent;
            localStorage.setItem('secret_key', secretKey);

            warningModal.classList.add('hidden');
            secretKeyModal.classList.remove('hidden');
            successMessage.classList.remove('hidden');

            setTimeout(() => {
                successMessage.classList.add('hidden');

